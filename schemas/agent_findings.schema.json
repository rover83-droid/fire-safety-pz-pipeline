{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent audit findings",
  "description": "Structured findings channel for audit agents. The pipeline merges this file into the machine-generated audit_report.json; agents never write the report directly.",
  "type": "object",
  "properties": {
    "level_1": { "$ref": "#/$defs/findings" },
    "level_2": { "$ref": "#/$defs/findings" }
  },
  "additionalProperties": false,
  "$defs": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 },
          "artifact": { "type": "string" },
          "severity": { "enum": ["error", "warning"] }
        },
        "required": ["message"],
        "additionalProperties": false
      }
    }
  }
}
