{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MPB PZ pipeline state",
  "type": "object",
  "required": ["version", "stage", "fkp", "section", "object_name", "last_updated"],
  "properties": {
    "version": { "type": "integer" },
    "stage": {
      "enum": ["fkp_detected", "passport_ready", "norms_extracted", "matrix_ready", "draft_ready", "audit_passed", "docx_ready"]
    },
    "fkp": {
      "enum": [
        "F1.1", "F1.2", "F1.3", "F1.4",
        "F2.1", "F2.2", "F2.3", "F2.4",
        "F3.1", "F3.2", "F3.3", "F3.4", "F3.5", "F3.6",
        "F4.1", "F4.2", "F4.3", "F4.4",
        "F5.1", "F5.2", "F5.3"
      ]
    },
    "section": { "type": "string" },
    "object_name": { "type": "string" },
    "last_updated": { "type": "string" },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
